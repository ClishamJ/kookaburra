    let runtime = tokio::runtime::Runtime::new()?;
    let pty_manager = PtyManager::new(event_tx.clone(), runtime.handle().clone());
    
    let mut app_state = AppState::new(config);
    let mut renderer = Renderer::new(&window)?;
    let mut ui = UiLayer::new();  // egui context
    
    event_loop.run(move |event, _, control_flow| {
        // Drain PTY events (non-blocking)
        while let Ok(pty_event) = event_rx.try_recv() {
            handle_pty_event(&mut app_state, pty_event);
        }
        
        match event {
            Event::WindowEvent { event, .. } => {
                // Route to ui layer first (it handles strip interactions)
                // If not consumed, route to focused tile's PTY
                ui.handle_event(&event, &mut app_state, &pty_manager);
            }
            Event::RedrawRequested(_) => {
                renderer.render_frame(&app_state, &mut ui)?;
            }
            _ => {}
        }
    });
}
The main loop is dumb. It drains events, routes input, draws. All logic lives in pure functions that take &mut AppState and a message. This makes the whole thing testable — you can write tests that say "given this state, when this event happens, the state becomes this" without any GPU or OS involvement.

